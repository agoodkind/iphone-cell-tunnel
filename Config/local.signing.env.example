# App Store Connect API key for automatic signing of the iOS device build.
# Copy this file to Config/local.signing.env (gitignored) and fill in real values,
# or export the same names in your environment. With nothing set, the device build
# falls back to the interactive Xcode account.
#
# Key id and issuer id come from App Store Connect, under Users and Access, then
# Integrations, then Keys.
APPLE_NOTARY_KEY_ID=
APPLE_NOTARY_ISSUER_ID=
# Path to the .p8 private key, kept outside the repo. When set, the path takes
# precedence over APPLE_NOTARY_KEY_BASE64.
APPLE_NOTARY_KEY_PATH=~/path/to/AuthKey_KEYID.p8
# Alternative to the path: base64 of the .p8, used by CI. Leave blank locally.
APPLE_NOTARY_KEY_BASE64=
